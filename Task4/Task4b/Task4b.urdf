<?xml version="1.0"?>
<robot name="trial">

    <material name="grey">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="green">
        <color rgba="0 0.6 0 1"/>
    </material>

    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <geometry>
                <box size="0.6 0.4 0.20"/>
            </geometry>
            <material name="green"/>
        </visual>

        <collision>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <geometry>
                <box size="0.70 0.50 0.30"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0.05"/>
            <mass value="5.0"/>
            <inertia
                ixx="0.03"
                ixy="0"
                ixz="0"
                iyy="0.05"
                iyz="0"
                izz="0.06"/>
        </inertial>
    </link>

    <link name="left_wheel_link">
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
            <material name="grey"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.5"/>
            <origin xyz="0 0 0"/>
            <inertia
                ixx="0.0005"
                ixy="0"
                ixz="0"
                iyy="0.0005"
                iyz="0"
                izz="0.00025"/>
        </inertial>
    </link>


    <link name="right_wheel_link">
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
            <material name="grey"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.5"/>
            <origin xyz="0 0 0"/>
            <inertia
                ixx="0.0005"
                ixy="0"
                ixz="0"
                iyy="0.0005"
                iyz="0"
                izz="0.00025"/>
        </inertial>

    </link>

    <link name="caster_wheel_link">
        <visual>
            <geometry>
                <sphere radius="0.045"/>
            </geometry>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <material name="grey"/>
        </visual>

        <collision>
            <geometry>
                <sphere radius="0.045"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.2"/>
            <origin xyz="0 0 0"/>
            <inertia
                ixx="0.0001"
                ixy="0"
                ixz="0"
                iyy="0.0001"
                iyz="0"
                izz="0.0001"/>
        </inertial>
    </link>

    <link name="base_footprint"/>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="-0.15 0.225 0.0" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="-0.15 -0.225 0.0" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <joint name="caster_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_link"/>
        <origin xyz="0.15 0.0 -0.04" rpy="0.0 0.0 0.0"/>
    </joint>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0.0 0.0 0.1" rpy="0.0 0.0 0.0"/>
    </joint>

    <gazebo reference="left_wheel">
        <mu1>100.0</mu1>
        <mu2>100.0</mu2>
    </gazebo>

  <gazebo reference="right_wheel">
        <mu1>100.0</mu1>
        <mu2>100.0</mu2>
  </gazebo>
i
    <gazebo>
        <plugin
            filename="libignition-gazebo-diff-drive-system.so"
            name="ignition::gazebo::systems::DiffDrive">

            <left_joint>left_wheel_joint</left_joint>
            <right_joint>right_wheel_joint</right_joint>

            <wheel_separation>0.23</wheel_separation>
            <wheel_radius>0.05</wheel_radius>

            <topic>/cmd_vel</topic>

            <odom_topic>/odom</odom_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_link</child_frame_id>

            <odom_publish_frequency>50</odom_publish_frequency>

        </plugin>
  </gazebo>
        
</robot>